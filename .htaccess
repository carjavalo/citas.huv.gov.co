<IfModule mod_rewrite.c>
    RewriteEngine On

    # Evitar bucle: no reescribir si ya empieza por public/
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond %{REQUEST_URI} !^/public$

    # Forzar que /Documentos/* pase por Laravel
    RewriteRule ^Documentos/(.*)$ public/index.php [L,QSA]

    # Redirigir todo lo demás al front controller en public/
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond %{REQUEST_URI} !^/public$
    RewriteRule ^(.*)$ public/$1 [L,QSA]
</IfModule>

# Hide the contents of directories
IndexIgnore public/Documentos/*
